# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 토스페이먼츠
NEXT_PUBLIC_TOSS_CLIENT_KEY=your-toss-client-key
TOSS_SECRET_KEY=your-toss-secret-key

# 알림톡 (카카오)
KAKAO_ALIMTALK_API_KEY=your-kakao-api-key
KAKAO_ALIMTALK_SENDER_KEY=your-sender-key

# 카카오맵 JavaScript SDK — 지도 표시용 (옵션). 주소 검색은 Daum Postcode를 사용하므로 키 불필요.
NEXT_PUBLIC_KAKAO_MAP_KEY=your-kakao-maps-javascript-key

# Web Push (PWA) - VAPID keys 발급: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@trainers.kr

# Vercel Cron Bearer secret (push dispatch endpoint 검증용)
CRON_SECRET=
